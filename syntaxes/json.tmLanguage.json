{
  "scopeName": "source.json",
  "name": "JSON",
  "fileTypes": ["json", "jsonc", "json5", "sublime-settings", "sublime-keymap", "sublime-commands"],
  "patterns": [
    { "include": "#value" }
  ],
  "repository": {
    "value": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#object" },
        { "include": "#array" },
        { "include": "#string" },
        { "include": "#number" },
        { "include": "#constant" }
      ]
    },
    "comment": {
      "patterns": [
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.json"
        },
        {
          "match": "//.*$",
          "name": "comment.line.double-slash.json"
        }
      ]
    },
    "object": {
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.dictionary.begin.json" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.dictionary.end.json" }
      },
      "name": "meta.structure.dictionary.json",
      "patterns": [
        { "include": "#comment" },
        { "include": "#property" },
        {
          "match": ",",
          "name": "punctuation.separator.dictionary.pair.json"
        }
      ]
    },
    "property": {
      "begin": "(\")((?:[^\"\\\\]|\\\\.)*)(\")",
      "end": "(?=[,}\\]])|(?<=[:,])",
      "beginCaptures": {
        "1": { "name": "punctuation.support.type.property-name.begin.json" },
        "2": { "name": "support.type.property-name.json" },
        "3": { "name": "punctuation.support.type.property-name.end.json" }
      },
      "patterns": [
        {
          "match": ":",
          "name": "punctuation.separator.dictionary.key-value.json"
        },
        { "include": "#value" }
      ]
    },
    "array": {
      "begin": "\\[",
      "end": "\\]",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.array.begin.json" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.array.end.json" }
      },
      "name": "meta.structure.array.json",
      "patterns": [
        { "include": "#value" },
        {
          "match": ",",
          "name": "punctuation.separator.array.json"
        }
      ]
    },
    "string": {
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.json" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.json" }
      },
      "name": "string.quoted.double.json",
      "patterns": [
        {
          "match": "\\\\(?:[\"\\\\bfnrt/]|u[0-9a-fA-F]{4})",
          "name": "constant.character.escape.json"
        }
      ]
    },
    "number": {
      "match": "-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?",
      "name": "constant.numeric.json"
    },
    "constant": {
      "match": "\\b(?:true|false|null)\\b",
      "name": "constant.language.json"
    }
  }
}
