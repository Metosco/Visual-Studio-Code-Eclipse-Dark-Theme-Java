{
  "comments": {
    "blockComment": ["<!--", "-->"]
  },
  "brackets": [
    ["<", ">"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "<!--", "close": " -->" },
    { "open": "<![CDATA[", "close": "]]>" },
    { "open": "<", "close": ">" }
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["'", "'"],
    ["<", ">"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*<(?!\\?|[^>]*\\/>)[^>]+>\\s*$",
    "decreaseIndentPattern": "^\\s*<\\/[^>]+>\\s*$"
  }
}
